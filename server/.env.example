# Variáveis do Spotgino Server.
# No Railway, defina-as em Service -> Variables. NÃO comite o .env real.

# Porta e host: no Railway o PORT é injetado automaticamente. Não defina PORT
# manualmente lá. HOST precisa ser 0.0.0.0 para o proxy do Railway alcançar o app.
HOST=0.0.0.0
# PORT=3333   # apenas para rodar local; no Railway deixe o Railway definir

# Nome exibido no /health e na home do servidor.
SERVER_NAME=Spotgino

# Origens permitidas (CORS). "*" libera todas. Para restringir, use uma lista
# separada por vírgula. O app Electron manda origin nulo, que é sempre aceito.
ALLOWED_ORIGINS=*

# Limites de salas.
MAX_ROOMS=500
MAX_MEMBERS_PER_ROOM=30
# Sala ociosa é limpa após esse tempo (ms). Padrão: 6h.
ROOM_IDLE_TTL_MS=21600000

# Caminho do banco SQLite. No Railway aponte para dentro do volume persistente
# (mount path /app/data), senão contas e amizades somem a cada deploy.
DB_FILE=/app/data/listen-together.db
